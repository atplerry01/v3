<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <IsPackable>false</IsPackable>
    <RootNamespace>Whycespace.WSS.Workflows.Tests</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="coverlet.collector" Version="6.0.4" />
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.14.1" />
    <PackageReference Include="xunit" Version="2.9.3" />
    <PackageReference Include="xunit.runner.visualstudio" Version="3.1.4" />
  </ItemGroup>

  <ItemGroup>
    <Using Include="Xunit" />
  </ItemGroup>

  <!-- Test files excluded: these reference deleted V1 APIs (old WorkflowInstanceRegistry
       with CreateWorkflowInstance/ResolveWorkflowInstance, old systems-layer WorkflowStateStore
       with PersistWorkflowState/GetWorkflowState, and WorkflowTemplateBlueprintEngine static methods).
       These need the V2 APIs to be re-implemented before they can be restored. -->
  <ItemGroup>
    <Compile Remove="WorkflowInstanceRegistryTests.cs" />
    <Compile Remove="WorkflowEventRouterTests.cs" />
    <Compile Remove="WorkflowStateStoreTests.cs" />
    <Compile Remove="WorkflowRegistryTests.cs" />
    <Compile Remove="WorkflowTemplateBlueprintEngineTests.cs" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\..\src\systems\Whycespace.System.csproj" />
    <ProjectReference Include="..\..\..\src\engines\T1M\WSS\Whycespace.Engines.T1M.WSS.csproj" />
    <ProjectReference Include="..\..\..\src\engines\T1M\orchestration\Whycespace.Engines.T1M.Orchestration.csproj" />
    <ProjectReference Include="..\..\..\src\engines\T1M\shared\Whycespace.Engines.T1M.Shared.csproj" />
    <ProjectReference Include="..\..\..\src\runtime\persistence\Whycespace.RuntimePersistence.csproj" />
    <ProjectReference Include="..\..\..\infrastructure\persistence\Whycespace.Infrastructure.Persistence.csproj" />
    <ProjectReference Include="..\..\..\src\runtime\workflow-runtime\Whycespace.WorkflowRuntime.csproj" />
  </ItemGroup>

</Project>
