@page
@model WorkflowsModel
@{
    ViewData["Title"] = "Workflows";
}

@if (Model.Workflows.ValueKind == System.Text.Json.JsonValueKind.Array && Model.Workflows.GetArrayLength() > 0)
{
    <table>
        <thead>
            <tr>
                <th>Workflow ID</th>
                <th>Name</th>
                <th>Status</th>
                <th>Current Step</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var wf in Model.Workflows.EnumerateArray())
        {
            var status = GetProp(wf, "status", "unknown");
            var badgeClass = status.ToLowerInvariant() switch
            {
                "completed" => "badge-active",
                "running" or "inprogress" => "badge-info",
                "failed" or "faulted" => "badge-error",
                _ => "badge-suspended"
            };
            <tr>
                <td><code>@GetProp(wf, "workflowId", "-")</code></td>
                <td>@GetProp(wf, "workflowName", "-")</td>
                <td><span class="badge @badgeClass">@status</span></td>
                <td>@GetProp(wf, "currentStep", "-")</td>
            </tr>
        }
        </tbody>
    </table>
}
else if (Model.Workflows.ValueKind == System.Text.Json.JsonValueKind.Object)
{
    <pre class="json-block">@FormatJson(Model.Workflows)</pre>
}
else
{
    <p class="empty-state">No workflow data available. Execute a command via the gateway to create workflow state.</p>
}

@functions {
    static string GetProp(System.Text.Json.JsonElement el, string name, string fallback)
    {
        if (el.ValueKind == System.Text.Json.JsonValueKind.Object && el.TryGetProperty(name, out var val))
            return val.ToString();
        return fallback;
    }

    static string FormatJson(System.Text.Json.JsonElement el) =>
        System.Text.Json.JsonSerializer.Serialize(el, new System.Text.Json.JsonSerializerOptions { WriteIndented = true });
}
